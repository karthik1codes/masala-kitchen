# Reactor (LingBot world model) — required
REACTOR_API_KEY=rk_your_api_key_here

# OpenAI — custom dish plans + DALL-E reference images (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

# TTS provider: sarvam | elevenlabs (auto-detects if unset)
TTS_PROVIDER=sarvam

# Sarvam AI — Bulbul v3 Indian voices for chef dialogue
# https://dashboard.sarvam.ai
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_LANGUAGE=hi-IN
SARVAM_CHEF_1_SPEAKER=shubh
SARVAM_CHEF_2_SPEAKER=ratan
SARVAM_CHEF_3_SPEAKER=sumit

# ElevenLabs (optional — set TTS_PROVIDER=elevenlabs to use)
ELEVENLABS_MODE=tts
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_LANGUAGE=hi
ELEVENLABS_CHEF_1_VOICE_ID=
ELEVENLABS_CHEF_2_VOICE_ID=
ELEVENLABS_CHEF_3_VOICE_ID=
