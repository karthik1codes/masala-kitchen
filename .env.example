# OpenAI — custom dish plans + DALL-E reference images
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium

REACTOR_API_KEY=

# TTS provider: sarvam | elevenlabs (defaults to sarvam when SARVAM_API_KEY is set)
TTS_PROVIDER=sarvam

# Sarvam AI — Bulbul v3 (recommended for Indian kitchen dialogue)
# https://dashboard.sarvam.ai
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_LANGUAGE=hi-IN
SARVAM_CHEF_1_SPEAKER=shubh
SARVAM_CHEF_2_SPEAKER=ratan
SARVAM_CHEF_3_SPEAKER=sumit

# ElevenLabs — optional fallback (set TTS_PROVIDER=elevenlabs)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_MODE=tts
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_LANGUAGE=hi
ELEVENLABS_CHEF_1_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVENLABS_CHEF_2_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_CHEF_3_VOICE_ID=SOYHLrjzK2X1ezoPC6cr
